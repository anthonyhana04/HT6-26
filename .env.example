# =============================================================================
# AI Council — environment configuration
# Copy to `.env` and fill in the values you have. Missing provider keys simply
# cause that council member to fall back to the built-in mock brain, so the
# orchestration engine remains fully demonstrable offline.
# =============================================================================

# --- Global engine behaviour -------------------------------------------------
# Force every agent to use the deterministic mock brain (great for demos / CI).
# When false, an agent uses its real provider only if the matching key is set.
AI_COUNCIL_FORCE_MOCK=false

# Minimum confidence (0-100) a proposal needs before the moderator will let an
# agent speak at all.
AI_COUNCIL_MIN_CONFIDENCE=55

# Confidence a proposal needs to interrupt an in-progress discussion.
AI_COUNCIL_INTERRUPT_CONFIDENCE=78
# Groq can interrupt a bit easier — still only for real nonsense.
AI_COUNCIL_GROQ_INTERRUPT_CONFIDENCE=70

# Maximum speakers the moderator will schedule from a single proposal round.
AI_COUNCIL_MAX_SPEAKERS=2

# Hard cap on total speaking turns per user message (prevents runaway loops).
AI_COUNCIL_MAX_TURNS=5

# How many times a single agent may speak per user message (fairness).
AI_COUNCIL_MAX_TURNS_PER_AGENT=2

# Max interrupt jumps per user message (stops pile-on fights).
AI_COUNCIL_MAX_INTERRUPTS=1

# --- Provider API keys -------------------------------------------------------
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
# xAI Grok — preferred backend for the Brutalist seat (Tesla/xAI Grok).
# Get a key at https://console.x.ai — when set, this overrides GROQ_API_KEY.
XAI_API_KEY=

# --- Model selection (optional overrides) ------------------------------------
# DeepSeek uses the OpenAI-compatible API (base_url is set for you).
DEEPSEEK_MODEL=deepseek-chat
ANTHROPIC_MODEL=claude-sonnet-4-6
GEMINI_MODEL=gemini-pro-latest
GROQ_MODEL=llama-3.3-70b-versatile
XAI_MODEL=grok-4.5

# --- Speech output -----------------------------------------------------------
# Where spoken lines go:
#   auto       -> ElevenLabs voices if ELEVENLABS_API_KEY is set, else terminal
#   elevenlabs -> force voices (falls back to terminal if the key is missing)
#   terminal   -> text only, no audio
AI_COUNCIL_SPEECH=auto

# --- ElevenLabs voices -------------------------------------------------------
# Set the key to give the council real voices. Each member gets a UNIQUE voice:
# set the per-member voice IDs below, or leave them blank and one will be
# auto-assigned from your account's available voices. Find IDs in the
# ElevenLabs Voice Library / "Voices" page.
ELEVENLABS_API_KEY=
# TTS model: eleven_flash_v2_5 (fastest/cheapest), eleven_turbo_v2_5, or
# eleven_multilingual_v2 (highest quality).
ELEVENLABS_MODEL=eleven_flash_v2_5
DEEPSEEK_VOICE_ID=
ANTHROPIC_VOICE_ID=
GEMINI_VOICE_ID=
GROK_VOICE_ID=
# GROQ_VOICE_ID=   # legacy alias — still accepted
# Neutral "Council adjourned" voice (pick a different ElevenLabs ID than Gemini).
ADJOURN_VOICE_ID=

# --- Lighting (WiZ bulb) -----------------------------------------------------
# IP of a WiZ smart bulb on your network. When set, the bulb switches to each
# speaker's colour as they talk and pulses with their voice amplitude. Find the
# IP in the WiZ app (device settings) or your router. Leave blank for no lights.
WIZ_BULB_IP=
WIZ_OFF_ON_EXIT=true
